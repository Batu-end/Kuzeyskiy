# Copy this file to .env and fill in your values
# Get your bot token from https://discord.com/developers/applications
DISCORD_TOKEN=your_bot_token_here

# Your Discord server ID (right-click server → Copy Server ID)
GUILD_ID=your_guild_id_here

# Your bot's application/client ID (from developer portal → General Information)
CLIENT_ID=your_client_id_here

# Optional: Spotify API credentials for faster Spotify metadata resolution
# Get from https://developer.spotify.com/dashboard
# Without these, Spotify links still work but slower via web scraping
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
